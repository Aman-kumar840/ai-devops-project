generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LogAnalysis {
  id             String         @id @default(uuid())
  buildName      String
  rawLog         String         @db.Text
  status         Status         @default(PENDING)
  rootCause      String?
  explanation    String?        @db.Text
  suggestedFixes SuggestedFix[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model SuggestedFix {
  id            String      @id @default(uuid())
  type          FixType
  description   String
  snippet       String      @db.Text
  logAnalysisId String
  logAnalysis   LogAnalysis @relation(fields: [logAnalysisId], references: [id])
}

enum Status {
  PENDING
  COMPLETED
  FAILED
}

enum FixType {
  COMMAND
  CODE
  CONFIG
}
